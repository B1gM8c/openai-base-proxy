# Address the proxy listens on.
BIND_ADDR=0.0.0.0:3000

# Upstream OpenAI-compatible API base. Defaults to https://api.openai.com.
UPSTREAM_BASE_URL=https://api.openai.com

# Optional proxy-side token. When set, clients must send:
#   x-proxy-token: <value>
PROXY_TOKEN=

# TCP connect timeout for the upstream, in seconds. Long OpenAI streams are not
# bounded by a total request timeout.
CONNECT_TIMEOUT_SECS=30
